{
  "version": 1,
  "name": "narrow-60cols",
  "description": "60 column narrow viewport",
  "viewport": { "cols": 60, "rows": 24 },
  "theme": "dark",
  "pollIntervalMs": 1000,
  "timeline": [
    { "at": 0, "type": "session_start", "name": "init" },
    { "at": 100, "type": "subagent_started", "agentId": "agent-1", "agentName": "narrow-test" },
    { "at": 300, "type": "activity", "agentId": "agent-1", "content": "Testing narrow layout" },
    { "at": 500, "type": "resize", "cols": 60, "rows": 24 },
    { "at": 700, "type": "checkpoint", "name": "narrow-layout-ready" }
  ]
}
