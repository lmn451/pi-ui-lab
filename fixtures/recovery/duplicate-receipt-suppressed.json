{
  "version": 1,
  "name": "duplicate-receipt-suppressed",
  "description": "Same receipt processed twice, second is suppressed",
  "viewport": { "cols": 80, "rows": 24 },
  "theme": "dark",
  "pollIntervalMs": 1000,
  "timeline": [
    { "at": 0, "type": "session_start", "name": "init" },
    { "at": 100, "type": "subagent_started", "agentId": "agent-1", "agentName": "receipt-agent" },
    { "at": 500, "type": "activity", "agentId": "agent-1", "content": "First event" },
    { "at": 1000, "type": "state_written", "key": "receipt-abc", "value": { "processed": true } },
    { "at": 1500, "type": "state_written", "key": "receipt-abc", "value": { "processed": true } },
    { "at": 2000, "type": "checkpoint", "name": "duplicate-suppressed" }
  ]
}
